# ============================================================
#  Voice MFA — Environment Variables
# ============================================================
#  Copy this file to .env and edit as needed:
#    cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://voicemfa:voicemfa@postgres:5432/voicemfa

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
JWT_SECRET_KEY=super-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_PRE_AUTH_EXPIRE_MINUTES=10
JWT_FULL_SESSION_EXPIRE_MINUTES=60

# Common naming equivalents used in some templates:
# SECRET_KEY -> JWT_SECRET_KEY
# ALGORITHM -> JWT_ALGORITHM
# ACCESS_TOKEN_EXPIRE_MINUTES -> JWT_FULL_SESSION_EXPIRE_MINUTES

# ── Voice Verification ──────────────────────────────────────
# Cosine similarity threshold (0.0–1.0). Lower = more lenient.
SIMILARITY_THRESHOLD=0.72
MIN_ENROLLMENT_SAMPLES=3
MAX_ENROLLMENT_SAMPLES=10

# ── Security ────────────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
CHALLENGE_EXPIRE_SECONDS=120

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
